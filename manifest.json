{
  "manifest_version": 3,
  "name": "Street View Preview for RideWithGPS",
  "version": "0.0.0",
  "description": "Adds a Google Street View preview to the RideWithGPS route planner/viewer. Hover over the route to see street view.",
  "homepage_url": "https://github.com/nslussar/rwgps-streetview",
  "permissions": ["storage", "webRequest"],
  "host_permissions": ["https://maps.googleapis.com/*", "https://ridewithgps.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Street View Preview",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://ridewithgps.com/routes/*"],
      "js": ["lib/usage.js", "content/api-budget.js", "lib/geo.js", "content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-bridge.js", "icons/heading-arrow.svg"],
      "matches": ["https://ridewithgps.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
