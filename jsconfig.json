{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "checkJs": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome"]
  },
  "include": [
    "background.js",
    "content/**/*.js",
    "lib/**/*.js",
    "popup/**/*.js",
    "test/**/*.js",
    "globals.d.ts"
  ],
  "exclude": [
    "scripts/demo-recording",
    "build",
    "node_modules"
  ]
}
